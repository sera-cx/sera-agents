# templates/web-chat — Express + browser chat UI over sera-mcp.

# Required.
OPENAI_API_KEY=sk-...

# Port the Express server listens on.
PORT=3000

# Path to sera-mcp build (overrides default lookup).
# SERA_MCP_DIST=/absolute/path/to/sera-mcp/dist/index.js

# Forwarded to the spawned sera-mcp child:
SERA_NETWORK=mainnet
SERA_SIGNER_MODE=external
SERA_ENABLE_EXECUTION_TOOLS=true
POLICY_PRESET=standard
