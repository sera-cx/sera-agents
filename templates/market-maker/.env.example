# market-maker template — two-sided spread bot

# Required.
OPENAI_API_KEY=sk-...

# Where the embedded sera-mcp will sign Order structs from. MUST be a wallet
# you've INTENTIONALLY funded for market-making, not a hot wallet of value.
SIGNER_PRIVATE_KEY=...

# Path to sera-mcp build.
# SERA_MCP_DIST=/absolute/path/to/sera-mcp/dist/index.js

# Forwarded to sera-mcp:
SERA_NETWORK=mainnet
SERA_SIGNER_MODE=local             # required — server signs Order structs
SERA_API_KEY=sera_...              # required for /balances + /orders reads
SERA_API_SECRET=...
SERA_ENABLE_EXECUTION_TOOLS=true

# Tight caps for a maker bot. Adjust upward only when you've verified the loop
# behaves correctly on tiny size.
POLICY_PRESET=starter
POLICY_MAX_NOTIONAL_USD=100        # per-order cap — start small
POLICY_DAILY_VOLUME_CAP_USD=1000   # rolling 24h kill switch
POLICY_DRY_RUN=false               # set true to paper-trade with no execution

# ── Maker loop knobs (read by agent.ts) ────────────────────────────────────
MM_PAIR=EURC/USDC                  # base/quote symbols (Sera market notation)
MM_NOTIONAL=100                    # USDC notional per side
MM_SPREAD_BPS=10                   # half-spread each side (0.10% × 2 = 0.20% round-trip)
MM_DRIFT_BPS=5                     # only requote when mid moves by this many bps
MM_POLL_SECONDS=3                  # tick interval
MM_EXPIRATION_SECONDS=3600         # how long each posted order lives
