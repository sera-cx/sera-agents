# templates/webhook-agent — HTTP webhook responder that runs an agent task per request.

# Required.
OPENAI_API_KEY=sk-...

# Port the Express server listens on.
PORT=3000

# ─── HMAC verification (recommended for production) ────────
# none (default) | stripe | github | generic
HMAC_PROVIDER=none
# HMAC_SECRET=replace-me
# HMAC_TOLERANCE_SECONDS=300

# Max concurrent agent tasks in flight (bounded slot pool).
# WEBHOOK_MAX_CONCURRENT=2

# Path to sera-mcp build.
# SERA_MCP_DIST=/absolute/path/to/sera-mcp/dist/index.js

# Forwarded to the spawned sera-mcp child:
SERA_NETWORK=mainnet
SERA_SIGNER_MODE=external
SERA_ENABLE_EXECUTION_TOOLS=false   # webhooks should NEVER expose execute_swap by default
POLICY_PRESET=standard
