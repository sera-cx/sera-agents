# taker template — cross-the-spread bot. Mirror of templates/market-maker.

# Path to the sera-mcp build. No default personal path — set this, or drop
# sera-mcp at ../../sera-mcp/dist/index.js next to this repo.
# SERA_MCP_DIST=/absolute/path/to/sera-mcp/dist/index.js

# The wallet that funds and receives takes. Required.
SERA_OWNER_ADDRESS=0xYourWallet

# Only needed for LIVE takes (TK_DRY_RUN=false). sera-mcp signs conversion
# intents from this key. Use a wallet you've INTENTIONALLY funded for this bot,
# not a hot wallet of value. Leave unset while paper-trading.
# SIGNER_PRIVATE_KEY=...

# Forwarded to sera-mcp:
SERA_NETWORK=sepolia               # start on sepolia; mainnet needs TK_MAINNET_ACK=true
SERA_API_KEY=sera_...              # required for /balances reads (inventory guard)
SERA_API_SECRET=...

# Tight caps — sera-mcp enforces these regardless of the loop knobs below.
POLICY_PRESET=starter
POLICY_MAX_NOTIONAL_USD=100        # per-take cap — start small
POLICY_DAILY_VOLUME_CAP_USD=1000   # rolling 24h kill switch
# POLICY_DRY_RUN=true              # belt-and-suspenders: also forces dry-run

# ── Taker loop knobs (read by agent.ts) ────────────────────────────────────
TK_PAIR=EURC/USDC                  # base/quote (Sera market notation)
TK_SIDE=buy                        # buy = acquire base; sell = offload base
TK_NOTIONAL=100                    # base units per take
TK_MIN_EDGE_BPS=15                 # only take when executable rate beats mid by this many bps
TK_POLL_SECONDS=30                 # tick interval
TK_DRY_RUN=true                    # THE live switch. true = print intended takes only
# TK_RECIPIENT=0x...               # defaults to SERA_OWNER_ADDRESS
# TK_MAINNET_ACK=true              # required to run live on mainnet
