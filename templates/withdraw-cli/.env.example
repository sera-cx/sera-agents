# withdraw-cli — walkthrough of Sera's dual-sig withdrawal flow

# Required.
OPENAI_API_KEY=sk-...

# sera-mcp wiring.
# SERA_MCP_DIST=/absolute/path/to/sera-mcp/dist/index.js
SERA_NETWORK=mainnet
SERA_SIGNER_MODE=external          # withdraw uses agent-side signing; server holds no key
SERA_API_KEY=sera_...
SERA_API_SECRET=...

# ── Withdrawal target (read by agent.ts) ─────────────────────────────────
WITHDRAW_USER=0xYourWallet
WITHDRAW_RECIPIENT=0xWhereTheTokensGo
WITHDRAW_TOKENS=0xTokenAddr1,0xTokenAddr2   # 1–20 token addresses
WITHDRAW_AMOUNTS=1000000,500000             # raw uint256 amounts (matching length)
