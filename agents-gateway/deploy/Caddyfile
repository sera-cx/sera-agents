# Caddyfile — agents.sera.cx reverse proxy (option b: split at proxy).
#
# Dynamic agent routes → the gateway container (gateway:8787, no TLS, no auth).
# Everything else → the static landing container (static:80). Caddy terminates
# TLS (automatic Let's Encrypt) for the agents.sera.cx host.
#
# Service names below — `gateway`, `static` — resolve via Docker's embedded DNS
# because all three containers share the same compose network. See the project
# root docker-compose.yml.
#
# The gateway already returns 429 + Retry-After when Sera throttles. reverse_proxy
# copies upstream response headers, so those backoff hints reach clients intact.
#
# OPTIONAL HARDENING — per-IP rate limit
# --------------------------------------
# To add a noisy-neighbor brake at the proxy, add a `rate_limit` block (see the
# template at the bottom). It requires the caddy-ratelimit plugin, which is NOT
# in the stock caddy:2-alpine image:
#
#   xcaddy build --with github.com/mholt/caddy-ratelimit
#
# Or swap the compose `caddy` service to a custom-built image. Without the plugin,
# Caddy fails to start on the rate_limit block — leave it commented out otherwise.

agents.sera.cx {
	encode zstd gzip

	# Dynamic — the gateway.
	@gateway path /mcp /mcp/* /openapi.json /health /quote /settle /corridors /rates
	handle @gateway {
		reverse_proxy gateway:8787 {
			header_up X-Forwarded-For {remote_host}
			health_uri      /health
			health_interval 10s
			health_timeout  2s
		}
	}

	# Everything else — static landing page + /docs/*.
	handle {
		reverse_proxy static:80
	}
}

# Template — drop into the `handle @gateway` block ABOVE `reverse_proxy` once
# you've built Caddy with caddy-ratelimit:
#
#   rate_limit {
#       zone agents_api {
#           key    {remote_host}
#           events 120
#           window 1m
#       }
#   }
