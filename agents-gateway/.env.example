# agents.sera.cx gateway configuration.

# Bind. Caddy in front handles TLS + host routing.
PORT=8787
HOST=0.0.0.0

# Sera upstream. mainnet | sepolia.
SERA_NETWORK=mainnet

# Optional. Set if you want Sera's account-level rate-limit/quota to apply.
# The 4 public tools (fx_quote, fx_settle, corridors, rates) work keyless without it.
# SERA_API_KEY=
# SERA_API_SECRET=

# Path to a built sera-mcp/dist/index.js. The Docker image bakes it at /opt/sera-mcp/dist/index.js.
# For local dev, clone sera-cx/sera-mcp at a pinned tag, run `npm ci && npm run build`, and point this here.
SERA_MCP_PATH=/opt/sera-mcp/dist/index.js

# Trust X-Forwarded-* from the reverse proxy. Set to 1 when behind Caddy.
TRUST_PROXY=1
