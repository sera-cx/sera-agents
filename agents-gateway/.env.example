# agents.sera.cx gateway — environment

# HTTP bind. Default 127.0.0.1 — front with a reverse proxy (TLS + the
# agents.sera.cx hostname) in production. Bind 0.0.0.0 only behind that proxy.
HOST=127.0.0.1
PORT=8787

# Which Sera network the embedded sera-mcp talks to.
#   mainnet -> https://api.sera.cx/api/v1      (chain_id 1)
#   sepolia -> https://api-testnet.sera.cx/api/v1 (chain_id 11155111)
SERA_NETWORK=mainnet

# Path to the built sera-mcp entrypoint. Clone + build sera-mcp next to this
# repo: `git clone https://github.com/sera-cx/sera-mcp && cd sera-mcp && npm i && npm run build`.
SERA_MCP_DIST=../sera-mcp/dist/index.js

# Optional Sera API credentials (only needed for endpoints that require auth,
# e.g. owner-scoped balances — the public read endpoints here do not use them).
# SERA_API_KEY=
# SERA_API_SECRET=

# NOTE: this gateway deliberately runs sera-mcp with SERA_SIGNER_MODE=readonly
# and SERA_ENABLE_EXECUTION_TOOLS=false (set by server.ts, not here). It can
# quote and return UNSIGNED typed data only — it can never sign, execute, or
# withdraw. Do NOT set SIGNER_PRIVATE_KEY for this process.
