# x402-service — protocol-level FX delivery endpoint (402 → pay USDC → swap → deliver).

# ─── Mode ───────────────────────────────────────────────────
# demo (default)  — self-contained; verifyPayment short-circuits; safe to run locally
# live            — currently intentional scaffold; verifyPayment returns "not yet implemented".
#                   See SECURITY-MODEL.md for the hardening checklist required before flipping.
X402_MODE=demo

# Port the Hono server listens on.
PORT=8402

# ─── Live-mode requirements (when X402_MODE=live — not production-complete) ─
# X402_FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402
# X402_CDP_API_KEY_ID=...
# X402_CDP_API_KEY_SECRET=...
# X402_NETWORK=base
# X402_USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
# X402_CONFIRMATION_DEPTH=3
# SERA_VAULT_ADDRESS=0x...        # where USDC payment lands

# ─── Sera execution wiring (used by both demo and live) ────
# X402 takes USDC payment then calls sera.convert_and_send. Requires
# sera-mcp running in local-signer mode with a funded vault.
SERA_NETWORK=mainnet
SERA_SIGNER_MODE=local
SIGNER_PRIVATE_KEY=...               # wallet that signs convert_and_send. Use a wallet
                                     # you've INTENTIONALLY funded for this purpose only.
SERA_API_KEY=sera_...
SERA_API_SECRET=...

# Policy caps for the embedded sera-mcp (tight defaults for x402 surface).
POLICY_PRESET=starter
POLICY_MAX_NOTIONAL_USD=500
POLICY_DAILY_VOLUME_CAP_USD=5000

# ─── Persistence ────────────────────────────────────────────
# SQLite path for x402 payment state machine (pending → verified → delivered).
X402_DB_PATH=./x402-state.db

# ─── Logging ────────────────────────────────────────────────
LOG_LEVEL=info
