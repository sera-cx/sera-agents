# sera-agents — shared env defaults for templates + examples.
# Copy individual values into per-package .env files as needed.

# ─── LLM provider (any one) ─────────────────────────────────
OPENAI_API_KEY=sk-...                # required by every template (chat-cli, web-chat, webhook-agent)
# ANTHROPIC_API_KEY=sk-ant-...       # if you swap the OpenAI Agents SDK out for an Anthropic client

# ─── sera-mcp wiring ────────────────────────────────────────
# Templates spawn sera-mcp as a stdio subprocess. Override if your build is
# elsewhere (default looks for ./sera-mcp/dist/index.js relative to the parent).
# SERA_MCP_DIST=/absolute/path/to/sera-mcp/dist/index.js

# ─── Sera network + auth (forwarded to sera-mcp child process) ─
SERA_NETWORK=mainnet                 # mainnet | sepolia
# SERA_API_KEY=sera_...               # only needed for treasury / settlement / account-flow tools
# SERA_API_SECRET=...

# ─── Sera execution mode ────────────────────────────────────
# external (default) — server holds no key, agent signs externally
# local              — server signs; ONLY use with intentionally-funded wallet
# readonly           — discovery + analytics only
SERA_SIGNER_MODE=external

# Set false to hide execute_swap + convert_and_send from the agent entirely.
# Recommended for public/multi-tenant deployments.
SERA_ENABLE_EXECUTION_TOOLS=true

# Policy preset for the embedded sera-mcp.
POLICY_PRESET=standard
